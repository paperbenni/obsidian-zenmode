{
	"name": "zenmode",
	"version": "1.6.5",
	"description": "Zen Mode",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"format": "prettier . --write",
		"dev": "node esbuild.config.mjs",
		"build": "pnpm run format && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"author": "@paperbenni",
	"license": "GPL-2.0",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@eslint/json": "^0.14.0",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^8.57.1",
		"@typescript-eslint/parser": "^8.57.1",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "17.4.0",
		"obsidian": "1.12.3",
		"prettier": "^3.8.1",
		"tslib": "2.8.1",
		"typescript": "5.9.3",
		"typescript-eslint": "8.57.1"
	},
	"packageManager": "pnpm@10.20.0"
}
