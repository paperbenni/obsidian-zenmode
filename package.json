{
	"name": "zenmode",
	"version": "1.6.6",
	"description": "Zen Mode",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"format": "prettier . --write",
		"dev": "node esbuild.config.mjs",
		"build": "pnpm run format && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"author": "@paperbenni",
	"license": "GPL-2.0",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@eslint/json": "^0.14.0",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^8.57.1",
		"@typescript-eslint/parser": "^8.57.1",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "17.4.0",
		"obsidian": "1.12.3",
		"prettier": "^3.8.1",
		"tslib": "2.8.1",
		"typescript": "5.9.3",
		"typescript-eslint": "8.57.1"
	},
	"packageManager": "pnpm@10.20.0",
	"pnpm": {
		"overrides": {
			"minimatch@<3.1.3": "^3.1.3",
			"minimatch@^4 || ^5 || ^6 || ^7 || ^8": "^8.0.5",
			"minimatch@^9": "^9.0.6",
			"picomatch@<2.3.2": "^2.3.2",
			"picomatch@^3 || ^4": "^4.0.4",
			"brace-expansion@<1.1.13": "^1.1.13",
			"brace-expansion@^2": "^2.0.3",
			"ajv@<6.14.0": "^6.14.0",
			"ajv@^7 || ^8": "^8.18.0",
			"flatted@<3.4.0": "^3.4.0",
			"fast-uri@<3.1.1": "^3.1.1",
			"yaml@<2.8.3": "^2.8.3"
		}
	}
}
